// Use .soql files to store SOQL queries.
// You can execute queries in VS Code by selecting the
//     query text and running the command:
//     SFDX: Execute SOQL Query with Currently Selected Text

SELECT Id, Name FROM Account

// Problem 3 — Find All Accounts With No Opportunities modified in the Last 90 Days
SELECT Id, Name, OwnerId, Phone
FROM Account
WHERE Id IN (SELECT AccountId FROM Opportunity WHERE LastModifiedDate < N_DAYS_AGO:90) ORDER BY Name